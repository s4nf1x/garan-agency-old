        font-size: 15px;
        line-height: 24px;
        text-align: center;
        color: #616E79;
    }
}

.packages {
    background: #F3F9FD;
    padding: 120px 0;
    .col-4 {
        padding: 0 10px;
    }
    .package-wrapper {
        margin: 0 -10px;
    }
    .package-cards {
        display: flex;
        width: 100%;
        flex-wrap: wrap;
    }
    .pack-card {
        padding: 40px 20px;
        background: #FFFFFF;
        box-shadow: 0 0 20px rgba(181, 188, 196, 0.25);
        border-radius: 10px;
        .title {
            font-weight: 700;
            font-size: 24px;
            line-height: 29px;
            text-align: center;
            color: #2C353D;
            margin-bottom: 12px;
        }
        .desc {
            font-size: 15px;
            line-height: 24px;
            text-align: center;
            color: #616E79;
            margin-bottom: 40px;
        }
        .price {
            font-weight: 700;
            font-size: 20px;
            line-height: 24px;
            text-align: center;
            color: #212833;
            margin-bottom: 20px;
            span {
                color: #28B4F2;
            }
        }
        .btn-blue {
            max-width: 100%;
        }
    }
}

.how-we-do {
    .title-section {
        margin-bottom: 60px;
    }
    .items-wrapper {
        counter-reset: section;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        margin: 0 -32px;
        .col-6 {
            padding: 0 32px;
        }
        li {
            font-weight: 600;
            font-size: 28px;
            line-height: 36px;
            color: #212833;
            display: flex;
            flex-wrap: wrap;
            width: 100%;
            flex-basis: 50%;
            max-width: 50%;
            margin-bottom: 60px;
            &:before {
                counter-increment: section;
                content: "0" counter(section) ".";
                font-size: 20px;
                line-height: 100%;
                color: #28B4F2;
                font-weight: 400;
                margin: 10px 6px 0 0;
            }
            p {
                width: 100%;
                font-size: 15px;
                line-height: 26px;
                color: #616E79;
                margin-top: 8px;
            }
        }
    }
}

