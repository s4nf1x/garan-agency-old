            .price {
                font-size: 18px;
                line-height: 22px;
                margin-bottom: 16px;
            }
        }
    }
    .how-we-do {
       .items-wrapper {
           li {
               max-width: 100%;
               flex-basis: 100%;
               font-size: 18px;
               line-height: 22px;
               &:not(:last-child) {
                   margin-bottom: 28px;
               }
               p {
                   margin-top: 4px;
               }
                &:before {
                    font-size: 14px;
                    margin: 4px 6px 0 0;
                }
           }
       }
    }
    footer {
        .col-12 {
            flex-wrap: wrap;
        }
        .left-bar {
            border-radius: 0;
            padding: 60px 20px;
        }
        .right-bar {
            padding: 60px 20px;
        }
        .nav-column {
            margin-bottom: 20px;
        }
        .copy {
            margin-bottom: 20px;
        }
        .policy {
            justify-content: flex-start;
        }
    }
}
