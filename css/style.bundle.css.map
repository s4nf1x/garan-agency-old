* {
    font-family: "Inter";
    box-sizing: border-box;
}
html, body, div, span, applet, object, iframe, h1, h2, h3, h4, h5, h6, p, blockquote, pre, a, abbr, acronym, address, big, cite, code, del, dfn, em, img, ins, kbd, q, s, samp, small, strike, strong, sub, sup, tt, var, b, u, i, center, dl, dt, dd, ol, ul, li, fieldset, form, label, legend, table, caption, tbody, tfoot, thead, tr, th, td, article, aside, canvas, details, embed, figure, figcaption, footer, header, hgroup, menu, nav, output, ruby, section, summary, time, mark, audio, video {
    margin: 0;
    padding: 0;
    border: 0;
    font-size: 100%;
    font: inherit;
    font-family: "Inter";
    vertical-align: baseline;
    outline: none;
}
html { height: 101%; } /* always display scrollbars */
body {
        font-size: 62.5%;
        line-height: 1;
        overflow-x: hidden;
    }
input {
    max-width: 100%;
}

article, aside, details, figcaption, figure, footer, header, hgroup, menu, nav, section { display: block; }
ol, ul { list-style: none; }

blockquote, q { quotes: none; }
blockquote:before, blockquote:after, q:before, q:after { content: ''; content: none; }
strong { font-weight: bold; }


input { outline: none; }



table { border-collapse: collapse; border-spacing: 0; }
img { border: 0; max-width: 100%; }
a {
    text-decoration: none;
    transition: 0.3s;
}
main {
    padding-top: 116px;
}
body.home {
    main {
        padding-top: 0;
    }
    .header-blue {
        background: transparent;
        .link {
            color: #fff;
            &:hover {
                color: #28b4f2;
            }
        }
        .navbar-menu .main-menu li a {
            color: #fff;
            &:hover {
                color: #28b4f2;
            }
        }
        .site-logo {
            background-image: url("../img/logo-home.png");
        }
        .callback {
            .btn {
                color: #fff;
                &:hover {
                    color: #fff;
                }
            }
        }
        .navbar-menu .main-menu .menu-item-has-children:after {
            background-image: url("../img/icons/menu-item-arrow.svg");
        }
    }
    .header-white {
        background: #fff;
        .callback .mail, .callback .phone {
            color: #212833;
            &:hover {
                color: #28b4f2;
            }
        }
        .navbar-menu .main-menu {
            .menu-item-has-children{
                &:after {
                    background-image: url("../img/icons/arrow-black.svg");
                }
                &:hover:after {
                    background-image: url("../img/icons/arrow-item-blue.svg");
                }
            }
        }
        .link, .navbar-menu .main-menu li a {
            color: #212833;
            &:hover {
                color: #28b4f2;
            }
        }
        .site-logo {
            background-image: url(../img/logo.png);
        }
        .callback .btn {
            color: #28b4f2;
            &:hover {
                color: #fff;
            }
        }
    }
}
a:hover {
    color: #28B4F2;
}
.link {
    transition: 0.3s;
    font-weight: 600;
    font-size: 15px;
    line-height: 100%;
    color: #212833;

    &:hover {
        color: #28B4F2;
    }
}
.container {
    max-width: 1188px;
    padding: 0 20px;
    width: 100%;
    display: flex;
    align-items: center;
    margin: auto;
    flex-wrap: wrap;
}

.container-fluid {
    max-width: 100%;
    width: 100%;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
}

.col-1 {
    width: 8.33333333%;
}
.col-2 {
    width: 16.66666667%;
}
.col-3 {
    width: 25%;
}
.col-4 {
    width: 33.33333333%;
}
.col-5 {
    width: 41.66666667%;
}
.col-6 {
    width: 50%;
}
.col-7 {
    width: 58.33333333%;
}
.col-8 {
    width: 66.66666667%;
}
.col-9 {
    width: 75%;
}
.col-10 {
    width: 83.33333333%;
}
.col-11 {
    width: 91.66666667%
}
.col-12 {
    width: 100%;
}

.swiper-button-next, .swiper-button-prev {
    background-color: #28B4F2;
    border-radius: 50%;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    top: -70px;
    transition: 0.3s;
    &:hover {
        background-color: #0084be;
    }
}
.swiper-button-next:after, .swiper-button-prev:after {
    content: "";
    background-image: url("../img/icons/accordion-arrow.svg");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    width: 30px;
    height: 30px;
}
.swiper-button-next:after {
    transform: rotate(270deg);
}
.swiper-button-prev {
    left: initial;
    right: 74px;
}
.swiper-button-prev:after {
    transform: rotate(90deg);
}
.accordion {
    width: 100%;
    .accordion-item {
        margin-bottom: 12px;
        width: 100%;
        cursor: pointer;
        background: #F3F9FD;
        border-radius: 10px;
        padding: 40px 28px;
        &:not(:last-child) {
            margin-bottom: 20px;
        }
        .accordion-item-content {
            overflow: hidden;
            border-top: none;
            max-height: 0;
            transition: 0.5s;
            width: 100%;
            padding-right: 60px;
            p {
                padding-top: 52px;
                font-size: 16px;
            }
        }
        .accordion-item-header {
            position: relative;
            font-weight: 600;
            font-size: 20px;
            line-height: 100%;
            color: #212833;
            display: flex;
            width: 100%;
            align-items: center;
            padding-right: 64px;
            &:after {
                content: "";
                display: block;
                background-color: #28B4F2;
                background-image: url(../img/icons/accordion-arrow.svg);
                background-repeat: no-repeat;
                background-position: center;
                background-size: 24px;
                border-radius: 50%;
                width: 48px;
                height: 48px;
                position: absolute;
                right: 0;
                transition: 0.2s;
            }
        }
    }
    .accordion-item.show {
        .accordion-item-header {
            &:after {
                transform: rotate(180deg);
            }
        }
        .accordion-item-content {
            max-height: 1000px;
            transition: all 2s;
        }
    }
}
.tag {
    font-weight: 600;
    font-size: 16px;
    line-height: 100%;
    color: #28B4F2;
    margin-bottom: 28px;
    display: block;
}
p {
    font-size: 18px;
    line-height: 30px;
    color: #616E79;
    &:not(:last-child) {
        margin-bottom: 30px;
    }
}
.row {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
}
.mobile-btn-menu {
    display: none;
}
.h3, h3 {
    font-weight: 700;
    font-size: 32px;
    line-height: 38px;
    color: #212833;
    margin-bottom: 12px;
}
.services-content {
    .content-info {
        max-width: 70%;
        margin: 0 auto 60px;

        ul {
            margin-left: 20px;
            max-width: 70%;
            li {
                font-size: 18px;
                line-height: 30px;
                color: #616E79;
                list-style: disc;
                margin-bottom: 16px;
                &::marker {
                    color: #28B4F2;
                }
            }
        }

        img {
            margin: 20px 0;
        }
    }
}
.content-policy {
    .content-info {
        max-width: 100%;
        margin: 0 0 60px;
    }
}
.btn {
    font-family: 'Inter';
    font-weight: 600;
    font-size: 16px;
    line-height: 100%;
    max-width: 146px;
    width: 100%;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px;
    color: #FFFFFF;
    border: 1px solid #28B4F2;
    border-radius: 200px;
    transition: all 0.3s;
    cursor: pointer;

    &:hover {
        background: #28B4F2;
        border: 1px solid #28B4F2;
        color: #fff;
    }
}
.btn-c-blue {
    color: #28B4F2;
    height: 56px;
}
.btn-c-white {
    color: #fff;
    border: 1px solid #fff;

    &:hover {
        background: #FFFFFF;
        border: 1px solid #FFFFFF;
        color: #28B4F2;
    }
}
.btn-blue {
    background: #28B4F2;
    max-width: 172px;

    &:hover {
        background: #0084BE;
        border: 1px solid #0084BE;
    }
}
.btn-load-more {
    max-width: 396px;
    margin: 80px auto 0;
}
.navigation-cases {
    display: flex;
    width: 100%;
    max-width: 70%;
    margin: 0 auto;
    justify-content: space-between;
}
.btn-w-arrow {
    max-width: 200px;
}
.btn-w-arrow.btn-next {
    margin-left: auto;
    &:after {
        content: "";
        display: inline-block;
        background-image: url("../img/icons/arrow-blue.svg");
        background-repeat: no-repeat;
        background-position: center;
        background-size: contain;
        width: 24px;
        height: 24px;
        margin-left: 10px;
        transform: rotate(180deg);
    }
    &:hover:after {
        background-image: url("../img/icons/arrow-white.svg");
    }
}
.btn-w-arrow.btn-prev {
    &:before {
        content: "";
        display: inline-block;
        background-image: url("../img/icons/arrow-blue.svg");
        background-repeat: no-repeat;
        background-position: center;
        background-size: contain;
        width: 24px;
        height: 24px;
        margin-right: 10px;
    }
    &:hover:before {
        background-image: url("../img/icons/arrow-white.svg");
    }
}
.title-section {
    font-family: 'Inter';
    font-weight: 700;
    font-size: 44px;
    line-height: 54px;
    color: #212833;
    margin-bottom: 40px;
    width: 100%;
    span {
        color: #28B4F2;
    }
}
.content-wrapper {
    position: relative;
    max-width: 400px;
    height: 400px;
    border: 18px solid #003D76;
    margin-left: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-repeat: no-repeat;
    background-size: cover;
}
.btn-play {
    display: block;
    position: absolute;
    background-color: #28B4F2;
    border-radius: 50%;
    background-image: url("../img/icons/play-fill.svg");
    background-position: center;
    background-repeat: no-repeat;
    background-size: 28px;
    width: 64px;
    height: 64px;
    cursor: pointer;
    transition: 0.3s;
    &:hover {
        background-color: #0084BE;
    }
}
.banner {
    margin-top: 120px;
    height: 522px;
    .title {
        font-weight: 700;
        font-size: 44px;
        line-height: 54px;
        color: #FFFFFF;
        margin-bottom: 16px;
        span {
            color: #28B4F2;
        }
    }
    .desc {
        font-size: 18px;
        line-height: 30px;
        color: #FFFFFF;
        margin-bottom: 28px;
    }
}
.overlay-lines {
    background-image: url(../img/overlay-line.png);
    background-repeat: no-repeat;
    background-position: 107% 0px;
    height: 1200px;
    position: absolute;
    right: 0;
    width: 100%;
    top: 0;
    background-size: 1040px;
}
.banner-page {
    background: #003D76;
    margin-top: 0;
    padding: 100px 0;
    margin-bottom: 280px;
    .content-wrapper {
        border-radius: 0;
        border: 0;
        height: 250px;
        max-width: 400px;
        margin: 0 0 0 auto;
        position: relative;
        bottom: -270px;
    }
}
.header {
    height: 116px;
    background: #fff;
    position: fixed;
    width: 100%;
    z-index: 222;
    .link:hover {
        color: #28B4F2;
    }
    .row {
        align-items: center;
    }
    .left-bar {
        display: flex;
        padding: 34px 0;
        align-items: center;
    }
    .right-bar {
        display: flex;
        padding: 34px 0;
        justify-content: space-between;
        align-items: center;
    }
    .callback {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        .btn {
            color: #28b4f2;
            &:hover {
                color: #fff;
            }
        }
        .mail, .phone {
            display: flex;
            align-items: center;
        }
        .mail:before, .phone:before {
            content: "";
            display: inline-block;
            margin-right: 10px;
            background-size: contain;
            background-position: center;
            background-repeat: no-repeat;
        }
        .mail:before {
            width: 18px;
            height: 14px;
            background-image: url("../img/icons/mail.svg");
        }
        .phone:before {
            width: 22px;
            height: 22px;
            background-image: url("../img/icons/phone.svg");
        }
    }
    .callback-mobile {
        display: none;
    }
    .site-logo {
        margin-right: 80px;
        background-image: url("../img/logo.png");
        background-repeat: no-repeat;
        background-position: center;
        background-size: contain;
        display: block;
        width: 100%;
        height: 36px;
        max-width: 211px;
    }
    .navbar-menu {
        display: flex;
        .main-menu {
            display: flex;
            li {
                padding: 10px 0;
                display: flex;
                align-items: center;
                a {
                    font-weight: 500;
                    font-size: 15px;
                    line-height: 18px;
                    letter-spacing: 0.1px;
                    color: #212833;
                    &:hover {
                        color: #28b4f2;
                    }
                }
            }
            .link-mobile {
                display: none;
            }
            li+li {
                padding-right: 32px;
            }
            .menu-item-has-children {
                position: relative;
                padding-bottom: 10px;
                transition: 0.3s;
                &:hover {
                    transition: 0.3s;
                    a {
                        color: #28b4f2;
                    }
                    .sub-menu {
                        display: block;
                    }
                    &:after {
                        transition: 0.2s;
                        background-image: url("../img/icons/arrow-item-blue.svg");
                    }
                }
                &:after {
                    content: "";
                    display: inline-block;
                    background-image: url(../img/icons/arrow-black.svg);
                    width: 10px;
                    height: 6px;
                    background-size: contain;
                    background-position: center;
                    background-repeat: no-repeat;
                    margin-left: 5px;
                }
                .sub-menu {
                    display: none;
                    position: absolute;
                    background: #fff;
                    padding: 24px;
                    width: 185px;
                    border-radius: 6px;
                    top: 37px;
                    left: -22%;
                    border: 1px solid #E7F1F9;
                    li {
                        padding: 0;
                        &:not(:last-child) {
                            margin-bottom: 8px;
                        }
                        a {
                            text-align: start;
                            color: #212833;
                            &:hover {
                                color: #28B4F2;
                            }
                        }
                    }
                    li+li  {
                        padding-left: 0;
                    }
                }
            }
        }
    }
}
.banner-home {
    background-color: #003D76;
    margin-top: 0;
    height: 100vh;
    padding: 0 0 100px;
    .col-6 {
        z-index: 1;
    }
}
.stats {
    margin-top: 80px;
    margin-bottom: 160px;
    .stats-items {
        box-shadow: 0 0 20px rgba(181, 188, 196, 0.25);
        border-radius: 10px;
        width: 100%;
        padding: 50px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        .stat-item {
            display: flex;
            align-items: flex-start;
            .stat-ico {
                margin-right: 22px;
                img {
                    max-width: 64px;
                    width: 100%;
                    object-fit: cover;
                }
            }
            .stat-info {
                .title {
                    font-family: 'Inter';
                    font-weight: 700;
                    font-size: 32px;
                    line-height: 100%;
                    color: #212833;
                    margin-bottom: 5px;
                }
                .desc {
                    font-weight: 500;
                    font-size: 16px;
                    line-height: 24px;
                    color: #212833;
                }
            }
        }
    }
}
.our-results {
    padding-bottom: 160px;
    .title-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 60px;
    }
    .results-list {
        margin: 0 -10px;
        .result-item {
            display: flex;
            flex-wrap: wrap;
            .btn {
                max-width: 172px;
            }
            &:not(:last-child) {
                margin-bottom: 60px;
            }
        }
        .col-6 {
            padding: 0 10px;
        }
        .result-title {
            font-weight: 600;
            font-size: 28px;
            line-height: 36px;
            color: #212833;
            margin-bottom: 8px;
        }
        .result-desc {
            font-size: 15px;
            line-height: 26px;
            color: #616E79;
            margin-bottom: 8px;
        }
        .img-result {
            max-width: 90%;
            margin-left: auto;
        }
    }
}

.our-services {
    padding-bottom: 160px;
    padding-top: 40px;
    .services-items {
        display: flex;
        flex-wrap: wrap;
        width: 100%;
        margin: 0 -10px;
        .col-6 {
            padding: 0 10px;
        }
        .services-item {
            box-shadow: 0 0 20px rgba(181, 188, 196, 0.25);
            border-radius: 10px;
            padding: 32px 28px 28px;
            margin-bottom: 20px;
            .title {
                font-weight: 700;
                font-size: 24px;
                line-height: 29px;
                margin-bottom: 12px;
            }
            .desc {
                font-size: 15px;
                line-height: 26px;
                margin-bottom: 50px;
            }
            .btn {
                height: 56px;
            }
        }
        .services-item.blue {
            background: #003D76;
            .title, .desc {
                color: #fff;
            }
        }
        .services-item.white {
            background: #fff;
            .title, .desc {
                color: #212833;
            }
        }
    }
}

.reviews {
    position: relative;
    padding-bottom: 160px;
    overflow: hidden;
    .swiper {
        width: 100%;
        overflow: initial;
    }
    .reviews-slider {
        &:before {
            content: "";
            background: #fff;
            width: 1000px;
            height: 340px;
            display: block;
            position: absolute;
            top: -40px;
            z-index: 99;
            left: -88%;
        }
    }
    .swiper-slide {
        display: flex;
        width: 55%;

        .video-review {
            max-width: 100%;
            width: 100%;
            height: 280px;
            border-radius: 10px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background-repeat: no-repeat;
            background-position: center;
            background-size: cover;
            .video-info {
                position: absolute;
                z-index: 1;
                bottom: 20px;
                left: 20px;
                .name {
                    font-weight: 700;
                    font-size: 16px;
                    line-height: 100%;
                    color: #FFFFFF;
                    margin-bottom: 8px;
                }
                .team {
                    font-size: 13px;
                    line-height: 100%;
                    color: #FFFFFF;
                }
            }
            .btn-play {
                z-index: 1;
            }
            &:after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: #003D76;
                opacity: 0.5;
                border-radius: 10px;
            }
        }
        .review-content {
            margin-left: 20px;
            box-shadow: 0 0 20px rgba(181, 188, 196, 0.25);
            border-radius: 10px;
            padding: 20px;
            max-width: 396px;
            width: 100%;
            height: 280px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            .desc {
                &:before {
                    content: "";
                    display: block;
                    width: 12px;
                    height: 16px;
                    background-image: url("../img/icons/quotes.svg");
                    background-size: contain;
                    background-position: center;
                    background-repeat: no-repeat;
                    margin-bottom: 8px;
                }
                p {
                    font-style: italic;
                    font-weight: 500;
                    font-size: 14px;
                    line-height: 22px;
                    color: #212833;
                }
            }
            .review-name {
                font-weight: 600;
                font-size: 15px;
                line-height: 22px;
                color: #212833;

            }
            .review-team {
                font-size: 13px;
                line-height: 22px;
                color: #616E79;
            }
        }
    }
}
.callback-section {
    margin-bottom: 160px;
    .title-section {
        color: #fff;
        text-align: center;
        margin-bottom: 16px;
    }
    .desc {
        font-size: 20px;
        line-height: 30px;
        text-align: center;
        color: #FFFFFF;
        margin-bottom: 40px;
    }

    form {
        width: 100%;
        background: #003D76;
        box-shadow: 0 0 20px rgba(181, 188, 196, 0.25);
        border-radius: 30px;
        padding: 80px 0;
        .form-inner {
            max-width: 856px;
            margin: auto;
        }
        .form-info {
            width: 100%;
        }
        .inputs-wrapper {
            display: flex;
            width: 100%;
            justify-content: space-between;
            flex-wrap: wrap;
            .btn {
                margin-top: 8px;
                text-align: center;
                justify-content: center;
                max-width: 100%;
                border-radius: 200px;
                border: none;
                color: #fff;
                padding: 0;
            }
        }
        .input-item {
            max-width: 49%;
            flex-basis: 49%;
            width: 100%;
            margin-bottom: 32px;
        }
        input {
            border: 1px solid #E7F1F9;
            border-radius: 6px;
            padding-left: 16px;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            height: 56px;
            width: 100%;
            font-weight: 600;
            font-size: 16px;
            line-height: 100%;
            color: #616E79;
            &::placeholder {
                font-weight: 600;
                font-size: 16px;
                line-height: 100%;
                color: #616E79;
            }
        }
    }
}

.callback-section-inline {
    background: #003D76;
    margin-bottom: 160px;
    .title-section, .desc {
        text-align: start;
    }
    form {
        border-radius: 0;
        background: transparent;
        box-shadow: none;
        .form-inner {
            max-width: 100%;
        }
        .input-item {
            max-width: 24%;
            flex-basis: 24%;
        }
        .inputs-wrapper {

            .btn {
                max-width: 24%;
                margin-top: 0;
                flex-basis: 24%;
            }
        }
    }
}


//* Footer

footer {
    background: #F3F9FD;
    .col-12 {
        display: flex;
    }
    .left-bar {
        background: #003D76;
        border-radius: 0 30px 30px 0;
        padding: 60px 70px;
    }
    .right-bar {
        padding: 60px 70px 32px 120px;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        width: 100%;
    }
    .contacts-info {
        .title {
            font-weight: 700;
            font-size: 24px;
            line-height: 29px;
            color: #FFFFFF;
            margin-bottom: 27px;
        }
    }
    .contact-item {
        color: #fff;
        margin-bottom: 32px;
        font-weight: 600;
        font-size: 15px;
        line-height: 22px;
    }

    .mail, .phone, .address {
        display: flex;
        align-items: center;
    }
    .mail:before, .phone:before, .address:before {
        content: "";
        display: inline-block;
        margin-right: 10px;
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
    }
    .address {
        align-items: flex-start;
    }
    .address:before {
        background-image: url("../img/icons/address-ico.svg");
        width: 24px;
        height: 26px;
    }
    .mail:before {
        width: 18px;
        height: 14px;
        background-image: url("../img/icons/mail.svg");
    }
    .phone:before {
        width: 22px;
        height: 22px;
        background-image: url("../img/icons/phone.svg");
    }
    .social-links {
        display: flex;
        width: 100%;
        .social-link {
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            width: 40px;
            height: 40px;
            display: block;
        }
        .linkedin {
            background-image: url("../img/icons/linkedin.svg");
            &:hover {
                background-image: url("../img/icons/linkedin-blue.svg");
            }
        }
        .social-link+.social-link {
            margin-left: 8px;
        }
    }
    .footer-nav {
        display: flex;
        flex-wrap: wrap;

        .title {
            font-weight: 700;
            font-size: 24px;
            line-height: 29px;
            color: #212833;
            margin-bottom: 20px;
        }

        ul {
            li {
                margin-bottom: 20px;

                a {
                    font-weight: 600;
                    font-size: 16px;
                    line-height: 100%;
                    color: #212833;
                    &:hover {
                        color: #28B4F2;
                    }

                }
            }
        }
    }

    .copy {
        font-weight: 500;
        font-size: 15px;
        line-height: 100%;
        color: #616E79;
    }
    .policy {
        font-weight: 600;
        font-size: 16px;
        line-height: 100%;
        color: #212833;
        display: flex;
        width: 100%;
        justify-content: flex-end;
        transition: 0.3s;
        &:hover {
            color: #28B4F2;
        }
    }
}
.services-content {
    margin-bottom: 160px;
    .about-desc {
        max-width: 69%;
        margin: auto;
        p {
            color: #212833;
        }
    }
